package components

import (
	"github.com/guilycst/GoATTH-penguinui/components/dropdown"
	"github.com/guilycst/GoATTH-penguinui/internal/pages/demo"
)

// DropdownDemoPage renders the Dropdown component demo
templ DropdownDemoPage() {
	@demo.Layout("Dropdown", "dropdown", dropdownDemoContent())
}

// dropdownDemoContent renders the actual content inside the layout
templ dropdownDemoContent() {
	@demo.ComponentDemo(
		demo.ComponentDemoProps{
			Title:         "Dropdown",
			Description:   "A dropdown menu displays a list of actions or options that a user can choose from. Supports click, hover, and context menu triggers with keyboard navigation.",
			OriginalURL:   "/original/dropdowns/dropdown-with-click.html",
			OriginalLabel: "Original PenguinUI",
			GoATTHLabel:   "GoATTH Component",
		},
		dropdownDemoPreview(),
		`// Click Dropdown
@dropdown.Dropdown(dropdown.Config{
    Label: "Actions Menu",
    Sections: []dropdown.Section{
        {Items: []dropdown.Item{
            {Label: "Dashboard", Href: "#"},
            {Label: "Subscription", Href: "#"},
            {Label: "Settings", Href: "#"},
            {Label: "Sign Out", Href: "#"},
        }},
    },
})

// Hover Dropdown
@dropdown.Dropdown(dropdown.Config{
    Label:       "Actions Menu",
    TriggerMode: dropdown.TriggerHover,
    Sections:    []dropdown.Section{...},
})

// Dropdown with Dividers
@dropdown.Dropdown(dropdown.Config{
    Label: "Actions Menu",
    Sections: []dropdown.Section{
        {Items: []dropdown.Item{
            {Label: "Dashboard", Href: "#"},
            {Label: "Messages", Href: "#"},
        }},
        {Items: []dropdown.Item{
            {Label: "Profile", Href: "#"},
            {Label: "Settings", Href: "#"},
        }},
        {Items: []dropdown.Item{
            {Label: "Sign Out", Href: "#"},
        }},
    },
})

// Context Menu
@dropdown.Dropdown(dropdown.Config{
    TriggerMode: dropdown.TriggerContext,
    Sections: []dropdown.Section{
        {Items: []dropdown.Item{
            {Label: "Undo", Icon: undoIcon(), Shortcut: "Z"},
        }},
        {Items: []dropdown.Item{
            {Label: "Cut", Icon: cutIcon(), Shortcut: "X"},
            {Label: "Copy", Icon: copyIcon(), Shortcut: "C"},
            {Label: "Paste", Icon: pasteIcon(), Shortcut: "V"},
        }},
    },
})`,
	)
}

// dropdownDemoPreview renders the GoATTH dropdown preview
templ dropdownDemoPreview() {
	<div class="w-full max-w-4xl mx-auto space-y-12">
		// Click Dropdown
		<div>
			<h4 class="text-sm font-medium mb-3 text-on-surface-strong dark:text-on-surface-dark-strong">Click to Open</h4>
			<div class="pb-2">
				@dropdown.Dropdown(dropdown.Config{
					ID:    "dropdown-click",
					Label: "Actions Menu",
					Sections: []dropdown.Section{
						{Items: []dropdown.Item{
							{Label: "Dashboard", Href: "#"},
							{Label: "Subscription", Href: "#"},
							{Label: "Settings", Href: "#"},
							{Label: "Sign Out", Href: "#"},
						}},
					},
				})
			</div>
		</div>

		// Hover Dropdown
		<div>
			<h4 class="text-sm font-medium mb-3 text-on-surface-strong dark:text-on-surface-dark-strong">Hover to Open</h4>
			<div class="pb-2">
				@dropdown.Dropdown(dropdown.Config{
					ID:          "dropdown-hover",
					Label:       "Actions Menu",
					TriggerMode: dropdown.TriggerHover,
					Sections: []dropdown.Section{
						{Items: []dropdown.Item{
							{Label: "Dashboard", Href: "#"},
							{Label: "Subscription", Href: "#"},
							{Label: "Settings", Href: "#"},
							{Label: "Sign Out", Href: "#"},
						}},
					},
				})
			</div>
		</div>

		// Dropdown with Dividers
		<div>
			<h4 class="text-sm font-medium mb-3 text-on-surface-strong dark:text-on-surface-dark-strong">With Dividers</h4>
			<div class="pb-2">
				@dropdown.Dropdown(dropdown.Config{
					ID:    "dropdown-divider",
					Label: "Actions Menu",
					Sections: []dropdown.Section{
						{Items: []dropdown.Item{
							{Label: "Dashboard", Href: "#"},
							{Label: "Messages", Href: "#"},
							{Label: "Favorites", Href: "#"},
						}},
						{Items: []dropdown.Item{
							{Label: "Profile", Href: "#"},
							{Label: "Settings", Href: "#"},
						}},
						{Items: []dropdown.Item{
							{Label: "Sign Out", Href: "#"},
						}},
					},
				})
			</div>
		</div>

		// Dropdown with Icons
		<div>
			<h4 class="text-sm font-medium mb-3 text-on-surface-strong dark:text-on-surface-dark-strong">With Icons</h4>
			<div class="pb-2">
				@dropdown.Dropdown(dropdown.Config{
					ID:    "dropdown-icons",
					Label: "Actions Menu",
					Sections: []dropdown.Section{
						{Items: []dropdown.Item{
							{Label: "Dashboard", Href: "#", Icon: ddDashboardIcon()},
							{Label: "Messages", Href: "#", Icon: ddMessagesIcon()},
							{Label: "Favorites", Href: "#", Icon: ddFavoritesIcon()},
						}},
						{Items: []dropdown.Item{
							{Label: "Profile", Href: "#", Icon: ddProfileIcon()},
							{Label: "Settings", Href: "#", Icon: ddSettingsIcon()},
						}},
						{Items: []dropdown.Item{
							{Label: "Help Center", Href: "#", Icon: ddHelpIcon()},
						}},
					},
				})
			</div>
		</div>

		// Context Menu
		<div>
			<h4 class="text-sm font-medium mb-3 text-on-surface-strong dark:text-on-surface-dark-strong">Context Menu</h4>
			<div class="pb-2">
				@dropdown.Dropdown(dropdown.Config{
					ID:          "dropdown-context",
					TriggerMode: dropdown.TriggerContext,
					Sections: []dropdown.Section{
						{Items: []dropdown.Item{
							{Label: "Undo", Icon: undoIcon(), Shortcut: "Z"},
						}},
						{Items: []dropdown.Item{
							{Label: "Cut", Icon: cutIcon(), Shortcut: "X"},
							{Label: "Copy", Icon: copyIcon(), Shortcut: "C"},
							{Label: "Paste", Icon: pasteIcon(), Shortcut: "V"},
						}},
						{Items: []dropdown.Item{
							{Label: "Print", Icon: printIcon(), Shortcut: "P"},
						}},
					},
				})
			</div>
		</div>

		// Actions Menu — button items with click handlers, disabled, danger
		<div x-data="{ editOpen: false, deleteOpen: false, editCount: 0 }">
			<h4 class="text-sm font-medium mb-3 text-on-surface-strong dark:text-on-surface-dark-strong">
				Actions Menu (button items: onclick / disabled / danger / icon-only trigger)
			</h4>
			<div class="pb-2 flex items-center gap-4">
				@dropdown.Dropdown(dropdown.Config{
					ID:              "dropdown-actions",
					Label:           "cluster actions",
					TriggerIcon:     ddDotsVerticalIcon(),
					TriggerIconOnly: true,
					Sections: []dropdown.Section{
						{Items: []dropdown.Item{
							{
								Label:   "Edit",
								Icon:    ddSettingsIcon(),
								OnClick: "editOpen = true; editCount++",
								ID:      "dropdown-actions-edit",
							},
							{
								Label:    "Archive",
								Icon:     ddFavoritesIcon(),
								Disabled: true,
								Tooltip:  "Archive not available in this state",
								ID:       "dropdown-actions-archive",
							},
						}},
						{Items: []dropdown.Item{
							{
								Label:   "Delete",
								Icon:    ddHelpIcon(),
								OnClick: "deleteOpen = true",
								Danger:  true,
								ID:      "dropdown-actions-delete",
							},
						}},
					},
				})
				<div class="text-xs text-on-surface/70 dark:text-on-surface-dark/70" id="dropdown-actions-state">
					editOpen=<span x-text="editOpen"></span>
					· deleteOpen=<span x-text="deleteOpen"></span>
					· editCount=<span x-text="editCount"></span>
				</div>
			</div>
		</div>
	</div>
}

// ddDotsVerticalIcon renders a vertical three-dots icon for overflow triggers
templ ddDotsVerticalIcon() {
	<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor" class="size-5">
		<path fill-rule="evenodd" d="M12 6.75a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3Zm0 6.75a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3Zm0 6.75a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3Z" clip-rule="evenodd"></path>
	</svg>
}

